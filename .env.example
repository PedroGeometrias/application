# Start in demo mode so evaluators can use the complete UI without credentials.
THREATLENS_DEMO_MODE=true

# Live provider mode
OTX_API_KEY=
VT_API_KEY=

# Optional AI briefing (deterministic briefings always remain available)
AI_BRIEFING_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Native core and report signing
THREATCORE_REQUIRED=true
REPORT_SIGNING_ENABLED=true

# Local persistence
THREATLENS_DB_PATH=./threatlens.db
